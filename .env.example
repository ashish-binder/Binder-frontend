# Binder-OS Frontend - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Backend API Base URL
# - Local (laptop): use .env.development with VITE_API_URL=http://localhost:8000/api/
#   (npm run dev loads .env.development automatically)
# - Production (Vercel): use .env.production or set VITE_API_URL in Vercel dashboard
#   e.g. https://binder-backend-0szj.onrender.com/api/
VITE_API_URL=https://binder-backend-0szj.onrender.com/api/

# Vercel Blob - for image uploads (factory code, artwork, packaging, etc.)
# Get token from Vercel Dashboard → Storage → Blob → Create token (read-write)
# See vercel_blob.md for details
VITE_BLOB_READ_WRITE_TOKEN=

# Google Sheets API (if needed)
# REACT_APP_API_URL=http://localhost:3000
# REACT_APP_SPREADSHEET_ID=your_spreadsheet_id_here

# ─── Binder COO chatbot (frontend-direct staging mode) ─────────────────────
# WebSocket gateway URL and authToken from the COO integration PDF v2.0.
# These DO end up in the JS bundle (Vite inlines any VITE_* var at build time).
# Acceptable for staging; for production roll back to the backend-proxied path
# served by /api/auth/me/coo-chat-config/ — see BINDER_COO_INTEGRATION.md.
VITE_COO_GATEWAY_URL=wss://binder-coo.tail2db2f3.ts.net/
VITE_COO_AUTH_TOKEN=
# Optional pre-fill for the in-chat UUID prompt. Leave blank to force the user
# to paste their own.
VITE_COO_DEFAULT_USER_ID=
